<script>
(function(){
  "use strict";
  var canvas=document.getElementById("board"),ctx=canvas.getContext("2d");
  var COLS=24,ROWS=24,CELL=24;
  canvas.width=COLS*CELL;canvas.height=ROWS*CELL;
  var scoreEl=document.getElementById("score"),highEl=document.getElementById("high"),
      overlay=document.getElementById("overlay"),overlayTitle=document.getElementById("overlayTitle"),
      overlayBody=document.getElementById("overlayBody");
  var S={READY:"ready",RUNNING:"running",PAUSED:"paused",OVER:"over"},state=S.READY;
  var snake,dir,nextDir,food,score,high,tickMs,acc,lastTime,rafId;

  function loadHigh(){try{var v=parseInt(localStorage.getItem("its_snake_high")||"0",10);return isFinite(v)?v:0;}catch(e){return 0;}}
  function saveHigh(v){try{localStorage.setItem("its_snake_high",String(v));}catch(e){}}
  high=loadHigh();highEl.textContent=high;

  function reset(){
    var cx=Math.floor(COLS/2),cy=Math.floor(ROWS/2);
    snake=[{x:cx-1,y:cy},{x:cx,y:cy},{x:cx+1,y:cy}];
    dir={x:1,y:0};nextDir={x:1,y:0};score=0;tickMs=130;acc=0;
    scoreEl.textContent="0";placeFood();
  }
  function placeFood(){while(true){var p={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)};
    if(!snake.some(function(s){return s.x===p.x&&s.y===p.y;})){food=p;return;}}}

  function startGame(){reset();state=S.RUNNING;hide();lastTime=performance.now();cancelAnimationFrame(rafId);rafId=requestAnimationFrame(loop);}
  function gameOver(){state=S.OVER;if(score>high){high=score;highEl.textContent=high;saveHigh(high);}show("Game over","Score "+score+" · Press <b>Space</b> to play again");draw();}
  function togglePause(){
    if(state===S.RUNNING){state=S.PAUSED;show("Paused","Press <b>Space</b> or <b>P</b> to resume");}
    else if(state===S.PAUSED){state=S.RUNNING;hide();lastTime=performance.now();rafId=requestAnimationFrame(loop);}
  }
  function loop(now){
    if(state!==S.RUNNING)return;
    var d=now-lastTime;lastTime=now;acc+=d;
    while(acc>=tickMs){step();acc-=tickMs;if(state!==S.RUNNING)return;}
    draw();rafId=requestAnimationFrame(loop);
  }
  function step(){
    if(nextDir.x!==-dir.x||nextDir.y!==-dir.y)dir=nextDir;
    var head=snake[snake.length-1],nx=head.x+dir.x,ny=head.y+dir.y;
    if(nx<0||ny<0||nx>=COLS||ny>=ROWS){gameOver();return;}
    var willEat=(nx===food.x&&ny===food.y),body=willEat?snake:snake.slice(1);
    if(body.some(function(s){return s.x===nx&&s.y===ny;})){gameOver();return;}
    snake.push({x:nx,y:ny});
    if(willEat){score+=10;scoreEl.textContent=score;if(tickMs>70)tickMs=Math.max(70,tickMs-3);placeFood();}
    else{snake.shift();}
  }
  function css(n){return getComputedStyle(document.documentElement).getPropertyValue(n).trim();}
  function draw(){
    ctx.fillStyle=css("--lcd")||"#aebd94";ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.strokeStyle="rgba(32,41,26,0.10)";ctx.lineWidth=1;
    for(var x=0;x<=COLS;x++){ctx.beginPath();ctx.moveTo(x*CELL+0.5,0);ctx.lineTo(x*CELL+0.5,canvas.height);ctx.stroke();}
    for(var y=0;y<=ROWS;y++){ctx.beginPath();ctx.moveTo(0,y*CELL+0.5);ctx.lineTo(canvas.width,y*CELL+0.5);ctx.stroke();}
    var ink=css("--ink")||"#20291a";
    var blink=state===S.RUNNING?(Math.floor(performance.now()/250)%2===0):true;
    if(blink)cell(food.x,food.y,ink,4);
    for(var i=0;i<snake.length;i++){var s=snake[i],head=i===snake.length-1;cell(s.x,s.y,ink,head?2:3);if(head)eyes(s);}
  }
  function cell(gx,gy,color,inset){ctx.fillStyle=color;ctx.fillRect(gx*CELL+inset,gy*CELL+inset,CELL-inset*2,CELL-inset*2);}
  function eyes(h){ctx.fillStyle=css("--lcd")||"#aebd94";var px=h.x*CELL,py=h.y*CELL,sz=3,ex=8+dir.x*4,ey=8+dir.y*4;
    ctx.fillRect(px+ex,py+ey,sz,sz);ctx.fillRect(px+CELL-ex-sz,py+ey,sz,sz);}
  function show(t,b){overlayTitle.innerHTML=t;overlayBody.innerHTML=b;overlay.hidden=false;}
  function hide(){overlay.hidden=true;}

  var KEYMAP={ArrowUp:{x:0,y:-1},KeyW:{x:0,y:-1},ArrowDown:{x:0,y:1},KeyS:{x:0,y:1},
    ArrowLeft:{x:-1,y:0},KeyA:{x:-1,y:0},ArrowRight:{x:1,y:0},KeyD:{x:1,y:0}};
  window.addEventListener("keydown",function(e){
    if(["ArrowUp","ArrowDown","ArrowLeft","ArrowRight","Space"].indexOf(e.code)>=0)e.preventDefault();
    if(e.code==="Space"){(state===S.READY||state===S.OVER)?startGame():togglePause();return;}
    if(e.code==="KeyP"){togglePause();return;}
    var d=KEYMAP[e.code];
    if(d&&state===S.RUNNING&&(d.x!==-dir.x||d.y!==-dir.y))nextDir=d;
  },{passive:false});

  var touchStart=null;
  canvas.addEventListener("touchstart",function(e){
    if(state===S.READY||state===S.OVER)startGame();
    if(e.touches.length)touchStart={x:e.touches[0].clientX,y:e.touches[0].clientY};
  },{passive:true});
  canvas.addEventListener("touchend",function(e){
    if(!touchStart||state!==S.RUNNING){touchStart=null;return;}
    var t=e.changedTouches[0],dx=t.clientX-touchStart.x,dy=t.clientY-touchStart.y;
    if(Math.abs(dx)<20&&Math.abs(dy)<20){touchStart=null;return;}
    var d=Math.abs(dx)>Math.abs(dy)?{x:dx>0?1:-1,y:0}:{x:0,y:dy>0?1:-1};
    if(d.x!==-dir.x||d.y!==-dir.y)nextDir=d;touchStart=null;
  },{passive:true});

  document.querySelectorAll("[data-dir]").forEach(function(btn){
    btn.addEventListener("click",function(){
      var map={up:{x:0,y:-1},down:{x:0,y:1},left:{x:-1,y:0},right:{x:1,y:0}},d=map[btn.getAttribute("data-dir")];
      if(state===S.READY||state===S.OVER){startGame();return;}
      if(d&&state===S.RUNNING&&(d.x!==-dir.x||d.y!==-dir.y))nextDir=d;
    });
  });
  var sb=document.getElementById("startBtn");
  if(sb)sb.addEventListener("click",function(){state===S.RUNNING?togglePause():startGame();});

  reset();draw();show("It's the Snake Game","Press <b>Space</b> to start<br>Steer with the <b>arrow keys</b>");
})();
</script>
</body>
</html>
